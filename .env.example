# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — required for destination candidate pool write-through (bypasses RLS).
# Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps Platform
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Browser/client Google Maps key.
# Restrict this key by HTTP referrer, e.g. localhost and production domain.
# Used for browser-side Maps/Places features.

GOOGLE_MAPS_API_KEY=
# Server-only Google Maps key.
# Do not expose this key to the browser.
# Used by backend/proxy routes such as /api/places/photo.
# Should allow server-side Places Photo requests.
# Keep Google Cloud quotas capped.

# Dev / quota protection: disable Google Place photo loading app-wide.
# Set both flags to true locally while quota is exhausted or to avoid photo costs.
# Server (DISABLE_PLACE_PHOTO_PROXY): /api/places/photo returns 404; backfill-photos
# and cover-image routes skip Google; /trips list skips cover backfill.
DISABLE_PLACE_PHOTO_PROXY=

# Client mirror (NEXT_PUBLIC_DISABLE_PLACE_PHOTO_PROXY): Plan thumbnails and trip
# cards use emoji/gradient fallbacks; no /api/places/photo or direct Google photo
# img requests. Does not delete stored cover_image_url or photo_url values.
NEXT_PUBLIC_DISABLE_PLACE_PHOTO_PROXY=

# Dev / quota protection: disable automatic Plan-tab sparse-day top-up.
# Set both flags to true locally to avoid surprise Google Places calls while browsing.
# Server (DISABLE_AUTO_FILL_SPARSE): /api/itinerary/fill-sparse-days returns
# { filledDays: 0, skipped: true } unless the request body includes explicit: true.
# Client (NEXT_PUBLIC_DISABLE_AUTO_FILL_SPARSE): Plan tab does not auto-POST
# fill-sparse-days on mount. Stored itinerary still renders normally.
# Generate itinerary remains a separate explicit user action (unchanged).
DISABLE_AUTO_FILL_SPARSE=

NEXT_PUBLIC_DISABLE_AUTO_FILL_SPARSE=

# Local testing only: mock hotel explore results without Google Places calls.
# When true, Explore hotels uses hardcoded sample hotels (no /api/places/autocomplete).
# Restart dev server after changing. Defaults to off when unset.
NEXT_PUBLIC_USE_MOCK_HOTEL_EXPLORE=

# Local testing only: mock destination autocomplete on Create Trip without Google calls.
# When true, /trips/new destination search uses hardcoded cities (no /api/places/autocomplete).
# Restart dev server after changing. Defaults to off when unset.
NEXT_PUBLIC_USE_MOCK_DESTINATION_AUTOCOMPLETE=

# App URL (for share links and OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: flight status refresh (AviationStack)
AVIATIONSTACK_API_KEY=
