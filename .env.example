# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Maps Platform
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Browser/client Google Maps key.
# Restrict this key by HTTP referrer, e.g. localhost and production domain.
# Used for browser-side Maps/Places features.

GOOGLE_MAPS_API_KEY=
# Server-only Google Maps key.
# Do not expose this key to the browser.
# Used by backend/proxy routes such as /api/places/photo.
# Should allow server-side Places Photo requests.
# Keep Google Cloud quotas capped.

# Dev only: skip Google photo fetches and return 404 so itinerary cards use emoji fallback.
DISABLE_PLACE_PHOTO_PROXY=

# App URL (for share links and OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: flight status refresh (AviationStack)
AVIATIONSTACK_API_KEY=
